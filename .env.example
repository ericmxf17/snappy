# Copy this file to .env and fill in real values. .env is gitignored.

# From the SnapTrade dashboard (Personal account API keys).
# These are the same PERS-... credentials the snaptrade CLI uses.
SNAPTRADE_CLIENT_ID=PERS-XXXXXXXXXXXXXXXXX
SNAPTRADE_CONSUMER_KEY=your_consumer_key_here

# From console.anthropic.com. Separate from any Claude Code login.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
